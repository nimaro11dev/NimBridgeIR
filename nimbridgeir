# -----------------------------------------------------------------------------
# Settings / enable / disable
# -----------------------------------------------------------------------------

show_status() {
  print_header
  bold "Current Status"
  load_config
  printf 'Access:               %s\n' "$( [[ "${NBI_ENABLED:-0}" == "1" ]] && printf 'Enabled' || printf 'Disabled' )"
  printf 'Proxy:                %s\n' "$(masked_proxy)"
  printf 'Access engine:        %s\n' "$( engine_installed && printf 'Ready' || printf 'Not prepared' )"
  printf 'Docker:               %s\n' "$( docker_installed && printf 'Installed' || printf 'Not installed' )"
  printf 'Docker access config: %s\n' "$( [[ "${NBI_DOCKER_ACCESS_CONFIGURED:-0}" == "1" ]] && printf 'Enabled' || printf 'Not enabled' )"
  printf 'Auto restore:         %s\n' "$( [[ "${NBI_AUTO_RESTORE_ON_DISABLE:-1}" == "1" ]] && printf 'Yes' || printf 'No' )"
  printf 'Config file:          %s\n' "$CONFIG_FILE"
  printf 'Log file:             %s\n' "$LOG_FILE"
  pause
}

enable_access() {
  load_config
  if ! has_access_config; then
    configure_access
    return $?
  fi
  NBI_ENABLED=1
  save_config
  bootstrap_install_engine && write_engine_config
  ok "$APP_NAME enabled."
  pause
}

disable_access() {
  print_header
  bold "Disable NimBridgeIR"
  load_config
  NBI_ENABLED=0
  save_config

  local do_restore
  do_restore="${NBI_AUTO_RESTORE_ON_DISABLE:-1}"
  if [[ "$do_restore" == "1" ]]; then
    read -rp 'Restore related system/Docker access config now? [Y/n]: ' answer
    case "${answer:-Y}" in
      y|Y|yes|YES) do_restore=1 ;;
      *) do_restore=0 ;;
    esac
  fi

  if [[ "$do_restore" == "1" ]]; then
    restore_latest_interrupted_session || true
    restore_docker_baseline || true
    cleanup_temp_access_files
    ok "$APP_NAME disabled and previous configs restored."
  else
    ok "$APP_NAME disabled. Existing configs were kept."
  fi
  pause
}

toggle_restore_behavior() {
  print_header
  bold "Restore Behavior"
  load_config
  printf 'Current auto restore on disable: %s\n\n' "$( [[ "${NBI_AUTO_RESTORE_ON_DISABLE:-1}" == "1" ]] && printf 'Yes' || printf 'No' )"
  read -rp 'Enable auto restore on disable? [Y/n]: ' ans
  case "${ans:-Y}" in
    y|Y|yes|YES) NBI_AUTO_RESTORE_ON_DISABLE=1 ;;
    *) NBI_AUTO_RESTORE_ON_DISABLE=0 ;;
  esac
  save_config
  ok "Restore behavior updated."
  pause
}

reset_settings() {
  print_header
  bold "Reset NimBridgeIR Settings"
  read -rp 'This will remove saved proxy settings. Continue? [y/N]: ' ans
  case "$ans" in
    y|Y|yes|YES)
      rm -f "$CONFIG_FILE" "$ENGINE_CONF"
      create_default_config
      ok "Settings reset."
      ;;
    *) warn "Canceled." ;;
  esac
  pause
}

uninstall_menu() {
  print_header
  bold "Uninstall NimBridgeIR"
  read -rp 'Uninstall NimBridgeIR from this server? [y/N]: ' ans
  case "$ans" in
    y|Y|yes|YES)
      if [[ -x "$UNINSTALLER" ]]; then
        bash "$UNINSTALLER"
      else
        warn "Uninstaller not found. Removing installed command only."
        rm -f /usr/local/bin/nimbridgeir /usr/local/bin/nbi
      fi
      ;;
    *) warn "Canceled."; pause ;;
  esac
}

settings_menu() {
  while true; do
    print_header
    bold "Settings"
    cat <<'EOF_MENU'
1) Show Current Status
2) Reconfigure Access
3) Enable NimBridgeIR
4) Disable NimBridgeIR
5) Restore Behavior
6) Reset NimBridgeIR Settings
7) Uninstall NimBridgeIR
0) Back
EOF_MENU
    printf '\nChoose: '
    read -r choice
    case "$choice" in
      1) show_status ;;
      2) configure_access ;;
      3) enable_access ;;
      4) disable_access ;;
      5) toggle_restore_behavior ;;
      6) reset_settings ;;
      7) uninstall_menu ;;
      0) return 0 ;;
      *) warn "Invalid option."; pause ;;
    esac
  done
}

main_menu() {
  require_root
  ensure_dirs
  load_config

  while true; do
    print_header
    cat <<'EOF_MENU'
1) Configure Access
2) Check Connection
3) Update Ubuntu Packages
4) Install Ubuntu Package
5) Download File
6) Clone GitHub Repository
7) Docker Tools
8) Run Custom Command
9) Settings
0) Exit
EOF_MENU
    printf '\nChoose: '
    read -r choice
    case "$choice" in
      1) configure_access ;;
      2) check_connection_menu ;;
      3) update_ubuntu_packages ;;
      4) install_ubuntu_package ;;
      5) download_file ;;
      6) clone_github_repo ;;
      7) docker_tools_menu ;;
      8) run_custom_command ;;
      9) settings_menu ;;
      0) exit 0 ;;
      *) warn "Invalid option."; pause ;;
    esac
  done
}

usage() {
  cat <<EOF_USAGE
$APP_NAME $NBI_VERSION

Usage:
  $APP_CMD                 Open interactive menu
  $APP_CMD --check         Check connection using saved config
  $APP_CMD --enable        Enable saved access config
  $APP_CMD --disable       Disable access config
  $APP_CMD --status        Show status
  $APP_CMD --version       Show version
EOF_USAGE
}

main() {
  case "${1:-}" in
    --help|-h) usage ;;
    --version|-v) printf '%s %s\n' "$APP_NAME" "$NBI_VERSION" ;;
    --check) require_root; load_config; check_connection_compact ;;
    --enable) require_root; enable_access ;;
    --disable) require_root; disable_access ;;
    --status) require_root; show_status ;;
    *) main_menu ;;
  esac
}

main "$@"
