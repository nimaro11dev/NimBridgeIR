# -----------------------------------------------------------------------------
# Basic UI helpers
# -----------------------------------------------------------------------------

bold() { printf '\033[1m%s\033[0m\n' "$*"; }
ok() { printf 'OK: %s\n' "$*"; }
warn() { printf 'Warning: %s\n' "$*"; }
err() { printf 'Error: %s\n' "$*" >&2; }

pause() {
  printf '\nPress Enter to continue...'
  read -r _ || true
}

log_msg() {
  local msg="$*"
  mkdir -p "$(dirname "$LOG_FILE")" 2>/dev/null || true
  printf '[%s] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$msg" >> "$LOG_FILE" 2>/dev/null || true
}

require_root() {
  if [[ "${EUID:-$(id -u)}" -ne 0 ]]; then
    err "Please run as root: sudo $APP_CMD"
    exit 1
  fi
}

ensure_dirs() {
 mkdir -p "$CONFIG_DIR" "$STATE_DIR" "$BACKUP_DIR" "$BASELINE_DIR" "$BRIDGE_STATE_DIR"
 chmod 700 "$CONFIG_DIR" "$STATE_DIR" "$BACKUP_DIR" "$BASELINE_DIR" "$BRIDGE_STATE_DIR" 2>/dev/null || true
}

print_header() {
  clear 2>/dev/null || true
  bold "$APP_NAME"
  printf 'Simple access helper for Ubuntu servers in Iran\n'
  printf 'by nimaro11 dev | version %s\n' "$NBI_VERSION"
  printf '%s\n\n' '----------------------------------------'
}

is_ubuntu() {
  [[ -r /etc/os-release ]] || return 1
  # shellcheck disable=SC1091
  . /etc/os-release
  [[ "${ID:-}" == "ubuntu" ]]
}

get_codename() {
  # shellcheck disable=SC1091
  . /etc/os-release
  printf '%s' "${VERSION_CODENAME:-}"
}

# -----------------------------------------------------------------------------
# Config handling
# -----------------------------------------------------------------------------

q() { printf '%q' "$1"; }

create_default_config() {
  [[ -f "$CONFIG_FILE" ]] && return 0
  cat > "$CONFIG_FILE" <<EOF_CONFIG
NBI_ENABLED=0
NBI_PROXY_TYPE=http
NBI_PROXY_RAW=
NBI_PROXY_HOST=
NBI_PROXY_PORT=
NBI_PROXY_USER=
NBI_PROXY_PASS=
NBI_BRIDGE_PORT=
NBI_AUTO_RESTORE_ON_DISABLE=1
NBI_DOCKER_ACCESS_CONFIGURED=0
NBI_NO_PROXY=$(q "$NBI_DEFAULT_NO_PROXY")
EOF_CONFIG
  chmod 600 "$CONFIG_FILE"
}

load_config() {
  ensure_dirs
  create_default_config
  # shellcheck disable=SC1090
  . "$CONFIG_FILE"
}

save_config() {
  local tmp
  tmp="$(mktemp)"
  {
    printf 'NBI_ENABLED=%q\n' "${NBI_ENABLED:-0}"
    printf 'NBI_PROXY_TYPE=%q\n' "${NBI_PROXY_TYPE:-http}"
    printf 'NBI_PROXY_RAW=%q\n' "${NBI_PROXY_RAW:-}"
    printf 'NBI_PROXY_HOST=%q\n' "${NBI_PROXY_HOST:-}"
    printf 'NBI_PROXY_PORT=%q\n' "${NBI_PROXY_PORT:-}"
    printf 'NBI_PROXY_USER=%q\n' "${NBI_PROXY_USER:-}"
    printf 'NBI_PROXY_PASS=%q\n' "${NBI_PROXY_PASS:-}"
    printf 'NBI_BRIDGE_PORT=%q\n' "${NBI_BRIDGE_PORT:-}"
    printf 'NBI_AUTO_RESTORE_ON_DISABLE=%q\n' "${NBI_AUTO_RESTORE_ON_DISABLE:-1}"
    printf 'NBI_DOCKER_ACCESS_CONFIGURED=%q\n' "${NBI_DOCKER_ACCESS_CONFIGURED:-0}"
    printf 'NBI_NO_PROXY=%q\n' "${NBI_NO_PROXY:-$NBI_DEFAULT_NO_PROXY}"
  } > "$tmp"
  install -m 600 "$tmp" "$CONFIG_FILE"
  rm -f "$tmp"
}

has_access_config() {
  [[ -n "${NBI_PROXY_RAW:-}" || ( -n "${NBI_PROXY_HOST:-}" && -n "${NBI_PROXY_PORT:-}" ) ]]
}

validate_port() {
  [[ "$1" =~ ^[0-9]+$ ]] && [[ "$1" -ge 1 && "$1" -le 65535 ]]
}

trim() {
 local value="$1"
 value="${value#"${value%%[![:space:]]*}"}"
 value="${value%"${value##*[![:space:]]}"}"
 printf '%s' "$value"
}

bridge_needed() {
 [[ "${NBI_PROXY_TYPE:-http}" != "http" ]]
}

urlencode() {
  local LC_ALL=C s="$1" i c out=""
  for (( i=0; i<${#s}; i++ )); do
    c="${s:i:1}"
    case "$c" in
      [a-zA-Z0-9.~_-]) out+="$c" ;;
      *) printf -v out '%s%%%02X' "$out" "'$c" ;;
    esac
  done
  printf '%s' "$out"
}

proxy_url() {
 if bridge_needed; then
  printf 'http://%s:%s' "$NBI_BRIDGE_LISTEN" "${NBI_BRIDGE_PORT:-}"
  return 0
 fi

  local host="${NBI_PROXY_HOST:-}" port="${NBI_PROXY_PORT:-}"
  local user="${NBI_PROXY_USER:-}" pass="${NBI_PROXY_PASS:-}"
  if [[ -n "$user" ]]; then
    printf 'http://%s:%s@%s:%s' "$(urlencode "$user")" "$(urlencode "$pass")" "$host" "$port"
  else
    printf 'http://%s:%s' "$host" "$port"
  fi
}

systemd_env_escape() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//%/%%}"
  printf '%s' "$value"
}

masked_proxy() {
  if [[ -z "${NBI_PROXY_HOST:-}" ]]; then
    printf 'not configured'
  elif bridge_needed; then
    printf '%s://%s:%s -> http://%s:%s' "${NBI_PROXY_TYPE:-proxy}" "${NBI_PROXY_HOST}" "${NBI_PROXY_PORT}" "$NBI_BRIDGE_LISTEN" "${NBI_BRIDGE_PORT:-not-ready}"
  elif [[ -n "${NBI_PROXY_USER:-}" ]]; then
    printf 'http://%s:***@%s:%s' "${NBI_PROXY_USER}" "${NBI_PROXY_HOST}" "${NBI_PROXY_PORT}"
  else
    printf 'http://%s:%s' "${NBI_PROXY_HOST}" "${NBI_PROXY_PORT}"
  fi
}

parse_access_input() {
 local raw="$1"
 raw="$(trim "$raw")"

 if [[ -z "$raw" ]]; then
  err "Proxy/config cannot be empty."
  return 1
 fi

 if ! command -v python3 >/dev/null 2>&1; then
  err "python3 is required to parse proxy configs."
  return 1
 fi

 local parsed rc
 parsed="$(python3 - "$raw" <<'PY'
import base64
import json
import sys
from urllib.parse import parse_qs, unquote, urlparse

raw = sys.argv[1].strip()

def fail(message):
    print("ERROR=" + json.dumps(message))
    sys.exit(2)

def emit(data):
    for key, value in data.items():
        if value is None:
            value = ""
        print(f"{key}={json.dumps(str(value))}")

def b64decode_padded(value):
    value = value.strip()
    value += "=" * (-len(value) % 4)
    return base64.urlsafe_b64decode(value.encode()).decode()

def safe_port(u, message):
    try:
        port = u.port
    except ValueError:
        fail(message)
    if port is None or port < 1 or port > 65535:
        fail(message)
    return port

u = urlparse(raw)
scheme = (u.scheme or "").lower()

if scheme == "http":
    port = safe_port(u, "HTTP proxy must be like http://host:port")
    if not u.hostname:
        fail("HTTP proxy must be like http://host:port")
    emit({
        "TYPE": "http",
        "RAW": raw,
        "HOST": u.hostname,
        "PORT": port,
        "USER": unquote(u.username or ""),
        "PASS": unquote(u.password or ""),
    })
    sys.exit(0)

if scheme in ("socks", "socks5", "socks4", "socks4a"):
    port = safe_port(u, "SOCKS proxy must be like socks5://host:port")
    if not u.hostname:
        fail("SOCKS proxy must be like socks5://host:port")
    proxy_type = "socks5" if scheme in ("socks", "socks5") else scheme
    emit({
        "TYPE": proxy_type,
        "RAW": raw,
        "HOST": u.hostname,
        "PORT": port,
        "USER": unquote(u.username or ""),
        "PASS": unquote(u.password or ""),
    })
    sys.exit(0)

if scheme == "vless":
    if not u.username or not u.hostname:
        fail("Invalid VLESS link.")
    query = parse_qs(u.query)
    security = (query.get("security", [""])[0] or "").lower()
    default_port = 443 if security in ("tls", "reality") else 80
    try:
        port = u.port or default_port
    except ValueError:
        fail("Invalid VLESS link.")
    emit({
        "TYPE": "vless",
        "RAW": raw,
        "HOST": u.hostname,
        "PORT": port,
        "USER": "",
        "PASS": "",
    })
    sys.exit(0)

if scheme == "vmess":
    payload = raw[len("vmess://"):]
    try:
        obj = json.loads(b64decode_padded(payload))
        port = int(obj.get("port"))
    except Exception:
        fail("Invalid VMess link.")
    host = obj.get("add") or obj.get("host")
    if not host or not obj.get("id") or port < 1 or port > 65535:
        fail("Invalid VMess link.")
    emit({
        "TYPE": "vmess",
        "RAW": raw,
        "HOST": host,
        "PORT": port,
        "USER": "",
        "PASS": "",
    })
    sys.exit(0)

fail("Supported inputs: http://, socks5://, socks4://, vless://, vmess://")
PY
)"

rc=$?

 if [[ $rc -ne 0 || "$parsed" == ERROR=* ]]; then
  local message="Proxy/config parse failed."
  if [[ "$parsed" == ERROR=* ]]; then
   message="$(python3 -c 'import json,sys; print(json.loads(sys.argv[1]))' "${parsed#ERROR=}" 2>/dev/null || printf '%s' "$message")"
  fi
  err "$message"
  return 1
 fi

 local line key value
 while IFS= read -r line; do
  [[ -n "$line" ]] || continue
  key="${line%%=*}"
  value="${line#*=}"
  value="$(python3 -c 'import json,sys; print(json.loads(sys.argv[1]))' "$value")" || return 1
  case "$key" in
   TYPE) NBI_PROXY_TYPE="$value" ;;
   RAW) NBI_PROXY_RAW="$value" ;;
   HOST) NBI_PROXY_HOST="$value" ;;
   PORT) NBI_PROXY_PORT="$value" ;;
   USER) NBI_PROXY_USER="$value" ;;
   PASS) NBI_PROXY_PASS="$value" ;;
  esac
 done <<< "$parsed"
}

sing_box_bin() {
 if [[ -x /usr/local/lib/nimbridgeir/sing-box ]]; then
  printf '%s' "/usr/local/lib/nimbridgeir/sing-box"
  return 0
 fi

 if command -v sing-box >/dev/null 2>&1; then
  command -v sing-box
  return 0
 fi

 return 1
}

bridge_port_free() {
 local port="$1"
 validate_port "$port" || return 1
 python3 - "$port" <<'PY' >/dev/null 2>&1
import socket
import sys

port = int(sys.argv[1])
sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
try:
    sock.bind(("127.0.0.1", port))
finally:
    sock.close()
PY
}

pick_bridge_port() {
 if [[ -n "${NBI_BRIDGE_PORT:-}" ]] && { bridge_port_free "$NBI_BRIDGE_PORT" || bridge_port_active "$NBI_BRIDGE_PORT"; }; then
  return 0
 fi

 local port
 port="$(python3 - "$NBI_BRIDGE_PORT_MIN" "$NBI_BRIDGE_PORT_MAX" <<'PY'
import random
import socket
import sys

start = int(sys.argv[1])
end = int(sys.argv[2])
ports = list(range(start, end + 1))
random.shuffle(ports)

for port in ports:
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    try:
        sock.bind(("127.0.0.1", port))
    except OSError:
        continue
    finally:
        sock.close()
    print(port)
    sys.exit(0)

sys.exit(1)
PY
)" || {
  err "Could not find a free local bridge port."
  return 1
 }

 NBI_BRIDGE_PORT="$port"
 save_config
}

bridge_service_active() {
 command -v systemctl >/dev/null 2>&1 && systemctl is-active --quiet "$NBI_BRIDGE_SERVICE" 2>/dev/null
}

bridge_port_active() {
 local port="$1"
 validate_port "$port" || return 1
 bridge_service_active || return 1
 ss -ltn 2>/dev/null | awk -v addr="$NBI_BRIDGE_LISTEN:$port" '$4 == addr { found=1 } END { exit !found }'
}

write_sing_box_config() {
 bridge_needed || return 0

 if [[ -z "${NBI_PROXY_RAW:-}" ]]; then
  err "Proxy/config is not saved."
  return 1
 fi

 if [[ -z "${NBI_BRIDGE_PORT:-}" ]]; then
  err "Local bridge port is not selected."
  return 1
 fi

 export NBI_PROXY_RAW NBI_PROXY_TYPE NBI_BRIDGE_PORT NBI_BRIDGE_LISTEN

 if ! python3 - "$SING_BOX_CONF" <<'PY'
import base64
import json
import os
import sys
from urllib.parse import parse_qs, unquote, urlparse

path = sys.argv[1]
raw = os.environ["NBI_PROXY_RAW"].strip()
listen = os.environ.get("NBI_BRIDGE_LISTEN", "127.0.0.1")
listen_port = int(os.environ["NBI_BRIDGE_PORT"])

def fail(message):
    raise SystemExit(message)

def first(query, *keys, default=""):
    for key in keys:
        value = query.get(key)
        if value and value[0] != "":
            return value[0]
    return default

def b64decode_padded(value):
    value = value.strip()
    value += "=" * (-len(value) % 4)
    return base64.urlsafe_b64decode(value.encode()).decode()

def add_tls(outbound, server, query=None, enabled=True, server_name=""):
    if not enabled:
        return
    query = query or {}
    tls = {"enabled": True}
    sni = server_name or first(query, "sni", "peer", "serverName", "servername", default=server)
    if sni:
        tls["server_name"] = sni
    fingerprint = first(query, "fp", "fingerprint")
    if fingerprint:
        tls["utls"] = {"enabled": True, "fingerprint": fingerprint}
    outbound["tls"] = tls

def add_reality(outbound, server, query):
    tls = {"enabled": True}
    sni = first(query, "sni", "peer", "serverName", "servername", default=server)
    if sni:
        tls["server_name"] = sni
    fingerprint = first(query, "fp", "fingerprint")
    if fingerprint:
        tls["utls"] = {"enabled": True, "fingerprint": fingerprint}
    reality = {"enabled": True}
    public_key = first(query, "pbk", "publicKey", "public_key")
    short_id = first(query, "sid", "shortId", "short_id")
    if not public_key:
        fail("Reality VLESS requires pbk/publicKey.")
    reality["public_key"] = public_key
    if short_id:
        reality["short_id"] = short_id
    tls["reality"] = reality
    outbound["tls"] = tls

def add_transport(outbound, network, query, host_header="", path_value=""):
    network = (network or "").lower()
    if network in ("", "tcp", "raw"):
        return

    if network == "ws":
        transport = {
            "type": "ws",
            "path": first(query, "path", default=path_value or "/"),
        }
        host = first(query, "host", "headers", default=host_header)
        if host:
            transport["headers"] = {"Host": host}
        outbound["transport"] = transport
        return

    if network == "grpc":
        service_name = first(query, "serviceName", "service_name", "path", default=path_value)
        outbound["transport"] = {
            "type": "grpc",
            "service_name": service_name,
        }
        return

    if network in ("http", "h2"):
        host = first(query, "host", default=host_header)
        transport = {
            "type": "http",
            "path": first(query, "path", default=path_value or "/"),
        }
        if host:
            transport["host"] = [host]
        outbound["transport"] = transport
        return

    fail(f"Unsupported transport: {network}")

def http_outbound(u):
    if not u.hostname or not u.port:
        fail("HTTP proxy must be like http://host:port")
    outbound = {
        "type": "http",
        "tag": "proxy-out",
        "server": u.hostname,
        "server_port": int(u.port),
    }
    if u.username:
        outbound["username"] = unquote(u.username)
        outbound["password"] = unquote(u.password or "")
    return outbound

def socks_outbound(u):
    if not u.hostname or not u.port:
        fail("SOCKS proxy must be like socks5://host:port")
    scheme = (u.scheme or "socks5").lower()
    version = "5"
    if scheme == "socks4":
        version = "4"
    elif scheme == "socks4a":
        version = "4a"
    outbound = {
        "type": "socks",
        "tag": "proxy-out",
        "server": u.hostname,
        "server_port": int(u.port),
        "version": version,
    }
    if u.username:
        outbound["username"] = unquote(u.username)
        outbound["password"] = unquote(u.password or "")
    return outbound

def vless_outbound(u):
    if not u.username or not u.hostname:
        fail("Invalid VLESS link.")
    query = parse_qs(u.query)
    security = first(query, "security").lower()
    default_port = 443 if security in ("tls", "reality") else 80
    outbound = {
        "type": "vless",
        "tag": "proxy-out",
        "server": u.hostname,
        "server_port": int(u.port or default_port),
        "uuid": unquote(u.username),
        "network": "tcp",
    }
    flow = first(query, "flow")
    if flow:
        outbound["flow"] = flow
    if security == "reality":
        add_reality(outbound, u.hostname, query)
    elif security == "tls":
        add_tls(outbound, u.hostname, query, enabled=True)
    network = first(query, "type", "network", default="tcp")
    add_transport(outbound, network, query)
    return outbound

def vmess_outbound(raw_value):
    payload = raw_value[len("vmess://"):]
    try:
        obj = json.loads(b64decode_padded(payload))
    except Exception as exc:
        fail(f"Invalid VMess link: {exc}")

    server = obj.get("add") or obj.get("host")
    port = obj.get("port")
    uuid = obj.get("id")
    if not server or not port or not uuid:
        fail("Invalid VMess link.")

    outbound = {
        "type": "vmess",
        "tag": "proxy-out",
        "server": server,
        "server_port": int(port),
        "uuid": uuid,
        "security": obj.get("scy") or "auto",
        "alter_id": int(obj.get("aid") or 0),
        "network": "tcp",
    }

    tls_value = (obj.get("tls") or "").lower()
    if tls_value and tls_value != "none":
        add_tls(outbound, server, enabled=True, server_name=obj.get("sni") or obj.get("host") or server)

    query = {
        "path": [obj.get("path") or ""],
        "host": [obj.get("host") or ""],
        "serviceName": [obj.get("serviceName") or ""],
    }
    add_transport(outbound, obj.get("net") or "tcp", query, host_header=obj.get("host") or "", path_value=obj.get("path") or "")
    return outbound

u = urlparse(raw)
scheme = (u.scheme or "").lower()

if scheme == "http":
    outbound = http_outbound(u)
elif scheme in ("socks", "socks5", "socks4", "socks4a"):
    outbound = socks_outbound(u)
elif scheme == "vless":
    outbound = vless_outbound(u)
elif scheme == "vmess":
    outbound = vmess_outbound(raw)
else:
    fail("Unsupported proxy/config type.")

config = {
    "log": {"level": "warn"},
    "inbounds": [
        {
            "type": "mixed",
            "tag": "local-in",
            "listen": listen,
            "listen_port": listen_port,
            "set_system_proxy": False,
        }
    ],
    "outbounds": [outbound],
    "route": {"final": "proxy-out"},
}

tmp = path + ".tmp"
with open(tmp, "w", encoding="utf-8") as f:
    json.dump(config, f, indent=2, ensure_ascii=False)
    f.write("\n")
os.replace(tmp, path)
PY
 then
  err "Could not generate sing-box config. Check your proxy/config link."
  return 1
 fi
 
 chmod 600 "$SING_BOX_CONF" || return 1
}

write_bridge_service() {
 local bin="$1"
 local bin_escaped conf_escaped
 bin_escaped="$(systemd_env_escape "$bin")"
 conf_escaped="$(systemd_env_escape "$SING_BOX_CONF")"

 cat > "$NBI_BRIDGE_SYSTEMD_SERVICE" <<EOF_BRIDGE_SERVICE
[Unit]
Description=NimBridgeIR local proxy bridge
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=$bin_escaped run -c $conf_escaped
Restart=on-failure
RestartSec=2
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=full

[Install]
WantedBy=multi-user.target
EOF_BRIDGE_SERVICE

 chmod 644 "$NBI_BRIDGE_SYSTEMD_SERVICE"
}

verify_bridge_local_bind() {
 local port="${NBI_BRIDGE_PORT:-}"
 validate_port "$port" || return 1

 if ss -ltn 2>/dev/null | awk -v p=":$port" '$4 ~ p {print $4}' | grep -Eq '^(0\.0\.0\.0|\[::\]|\*)'; then
  err "Local bridge is exposed on a public interface. Stopping it."
  systemctl stop "$NBI_BRIDGE_SERVICE" >/dev/null 2>&1 || true
  return 1
 fi

 if ! ss -ltn 2>/dev/null | awk -v p=":$port" '$4 ~ p {print $4}' | grep -q "^127\.0\.0\.1:$port\$"; then
  err "Local bridge did not bind to 127.0.0.1:$port."
  systemctl stop "$NBI_BRIDGE_SERVICE" >/dev/null 2>&1 || true
  return 1
 fi
}

stop_local_bridge() {
 if command -v systemctl >/dev/null 2>&1; then
  systemctl disable --now "$NBI_BRIDGE_SERVICE" >/dev/null 2>&1 || true
  systemctl daemon-reload >/dev/null 2>&1 || true
 fi
}

local_bridge_status() {
 if ! bridge_needed; then
  printf 'Not required'
  return 0
 fi

 if bridge_service_active && [[ -n "${NBI_BRIDGE_PORT:-}" ]]; then
  printf 'Running on %s:%s' "$NBI_BRIDGE_LISTEN" "$NBI_BRIDGE_PORT"
 else
  printf 'Not running'
 fi
}

ensure_local_bridge() {
 local force="${1:-0}"
 bridge_needed || return 0

 if [[ "$force" != "1" ]] && bridge_service_active && verify_bridge_local_bind; then
  return 0
 fi

 if ! command -v python3 >/dev/null 2>&1; then
  err "python3 is required for SOCKS/VLESS/VMess configs."
  return 1
 fi

 local bin
 if ! bin="$(sing_box_bin)"; then
  err "sing-box is required for ${NBI_PROXY_TYPE:-this config}. Put the bundled binary at: /usr/local/lib/nimbridgeir/sing-box"
  return 1
 fi

 pick_bridge_port || return 1
 write_sing_box_config || return 1

 if ! "$bin" check -c "$SING_BOX_CONF" >/dev/null 2>&1; then
  err "sing-box config check failed. Check your proxy/config link."
  return 1
 fi

 if ! command -v systemctl >/dev/null 2>&1; then
  err "systemd is required for the local bridge service."
  return 1
 fi

 write_bridge_service "$bin"
 systemctl daemon-reload || return 1
 systemctl enable "$NBI_BRIDGE_SERVICE" >/dev/null 2>&1 || true
 systemctl restart "$NBI_BRIDGE_SERVICE" >/dev/null 2>&1 || {
  err "Could not restart local bridge."
  return 1
 }

 sleep 1
 verify_bridge_local_bind || return 1
}

# -----------------------------------------------------------------------------
# Backup / restore helpers hidden from user-facing menu
# -----------------------------------------------------------------------------

new_session_dir() {
  local sid
  sid="$(date '+%Y%m%d_%H%M%S')_$$"
  mkdir -p "$BACKUP_DIR/$sid"
  touch "$BACKUP_DIR/$sid/in-progress"
  printf '%s' "$BACKUP_DIR/$sid"
}

backup_resolv() {
  local session="$1"
  mkdir -p "$session/resolv"
  if [[ -L /etc/resolv.conf ]]; then
    readlink /etc/resolv.conf > "$session/resolv/type-symlink"
  elif [[ -e /etc/resolv.conf ]]; then
    cp -a /etc/resolv.conf "$session/resolv/resolv.conf"
    printf 'file' > "$session/resolv/type-file"
  else
    printf 'absent' > "$session/resolv/type-absent"
  fi
}

restore_resolv() {
  local session="$1"
  [[ -d "$session/resolv" ]] || return 0
  rm -f /etc/resolv.conf
  if [[ -f "$session/resolv/type-symlink" ]]; then
    ln -s "$(cat "$session/resolv/type-symlink")" /etc/resolv.conf
  elif [[ -f "$session/resolv/type-file" ]]; then
    cp -a "$session/resolv/resolv.conf" /etc/resolv.conf
  else
    rm -f /etc/resolv.conf
  fi
}

apply_temp_dns() {
  cat > /etc/resolv.conf <<EOF_DNS
nameserver $NBI_BOOTSTRAP_DNS_1
nameserver $NBI_BOOTSTRAP_DNS_2
options timeout:2 attempts:2
EOF_DNS
}

backup_apt_sources() {
  local session="$1"
  mkdir -p "$session/apt"
  if [[ -f /etc/apt/sources.list ]]; then
    cp -a /etc/apt/sources.list "$session/apt/sources.list"
  else
    printf 'absent' > "$session/apt/sources.list.absent"
  fi
  if [[ -d /etc/apt/sources.list.d ]]; then
    tar -C /etc/apt -czf "$session/apt/sources.list.d.tar.gz" sources.list.d
  else
    printf 'absent' > "$session/apt/sources.list.d.absent"
  fi
}

restore_apt_sources() {
  local session="$1"
  [[ -d "$session/apt" ]] || return 0
  if [[ -f "$session/apt/sources.list" ]]; then
    cp -a "$session/apt/sources.list" /etc/apt/sources.list
  else
    rm -f /etc/apt/sources.list
  fi
  rm -rf /etc/apt/sources.list.d
  if [[ -f "$session/apt/sources.list.d.tar.gz" ]]; then
    tar -C /etc/apt -xzf "$session/apt/sources.list.d.tar.gz"
  else
    mkdir -p /etc/apt/sources.list.d
  fi
}

apply_bootstrap_apt_sources() {
  local codename
  codename="$(get_codename)"
  if [[ -z "$codename" ]]; then
    err "Cannot detect Ubuntu codename."
    return 1
  fi
  mkdir -p /etc/apt/sources.list.d
  rm -rf /etc/apt/sources.list.d
  mkdir -p /etc/apt/sources.list.d
  cat > /etc/apt/sources.list <<EOF_APT
deb $NBI_BOOTSTRAP_APT_MIRROR $codename main restricted universe multiverse
deb $NBI_BOOTSTRAP_APT_MIRROR $codename-updates main restricted universe multiverse
deb $NBI_BOOTSTRAP_APT_MIRROR $codename-backports main restricted universe multiverse
deb $NBI_BOOTSTRAP_SECURITY_MIRROR $codename-security main restricted universe multiverse
EOF_APT
}

backup_docker_once() {
  mkdir -p "$BASELINE_DIR/docker"

  # v0.1.0/v0.1.1 used "marker" for daemon.json. Keep compatibility.
  if [[ ! -f "$BASELINE_DIR/docker/daemon.marker" ]]; then
    if [[ -f "$BASELINE_DIR/docker/marker" ]]; then
      cp -a "$BASELINE_DIR/docker/marker" "$BASELINE_DIR/docker/daemon.marker"
    elif [[ -f /etc/docker/daemon.json ]]; then
      cp -a /etc/docker/daemon.json "$BASELINE_DIR/docker/daemon.json"
      printf 'file' > "$BASELINE_DIR/docker/daemon.marker"
    else
      printf 'absent' > "$BASELINE_DIR/docker/daemon.marker"
    fi
  fi

  if [[ ! -f "$BASELINE_DIR/docker/systemd.marker" ]]; then
    if [[ -f "$DOCKER_SYSTEMD_PROXY_CONF" ]]; then
      cp -a "$DOCKER_SYSTEMD_PROXY_CONF" "$BASELINE_DIR/docker/systemd-proxy.conf"
      printf 'file' > "$BASELINE_DIR/docker/systemd.marker"
    else
      printf 'absent' > "$BASELINE_DIR/docker/systemd.marker"
    fi
  fi
}

restore_docker_baseline() {
  local daemon_marker="$BASELINE_DIR/docker/daemon.marker"
  [[ -f "$daemon_marker" ]] || daemon_marker="$BASELINE_DIR/docker/marker"

  mkdir -p /etc/docker
  if [[ -f "$daemon_marker" ]] && grep -qx 'file' "$daemon_marker"; then
    cp -a "$BASELINE_DIR/docker/daemon.json" /etc/docker/daemon.json
  elif [[ -f "$daemon_marker" ]]; then
    rm -f /etc/docker/daemon.json
  fi

  if [[ -f "$BASELINE_DIR/docker/systemd.marker" ]] && grep -qx 'file' "$BASELINE_DIR/docker/systemd.marker"; then
    mkdir -p "$(dirname "$DOCKER_SYSTEMD_PROXY_CONF")"
    cp -a "$BASELINE_DIR/docker/systemd-proxy.conf" "$DOCKER_SYSTEMD_PROXY_CONF"
  else
    rm -f "$DOCKER_SYSTEMD_PROXY_CONF"
  fi

  if command -v systemctl >/dev/null 2>&1 && systemctl list-unit-files docker.service >/dev/null 2>&1; then
    systemctl daemon-reload >/dev/null 2>&1 || true
    systemctl restart docker >/dev/null 2>&1 || true
  fi
  NBI_DOCKER_ACCESS_CONFIGURED=0
  save_config
}

cleanup_temp_access_files() {
  rm -f /etc/apt/apt.conf.d/99nimbridgeir-access 2>/dev/null || true
  rm -f /etc/apt/sources.list.d/nimbridgeir-bootstrap.list 2>/dev/null || true
}

restore_latest_interrupted_session() {
  local latest
  latest="$(find "$BACKUP_DIR" -mindepth 2 -maxdepth 2 -name in-progress -type f 2>/dev/null | sed 's#/in-progress$##' | sort | tail -n 1 || true)"
  [[ -n "$latest" ]] || return 0
  restore_apt_sources "$latest" || true
  restore_resolv "$latest" || true
  rm -f "$latest/in-progress"
  touch "$latest/restored-after-interruption"
  cleanup_temp_access_files
}

# -----------------------------------------------------------------------------
# Access engine internals
# -----------------------------------------------------------------------------

engine_installed() {
  command -v proxychains4 >/dev/null 2>&1 && command -v python3 >/dev/null 2>&1
}

write_engine_config() {
  has_access_config || return 1
  cat > "$ENGINE_CONF" <<EOF_ENGINE
strict_chain
proxy_dns
remote_dns_subnet 224
tcp_read_time_out 15000
tcp_connect_time_out 8000

[ProxyList]
EOF_ENGINE
  local engine_host engine_port engine_user engine_pass

 if bridge_needed; then
  engine_host="$NBI_BRIDGE_LISTEN"
  engine_port="${NBI_BRIDGE_PORT:-}"
  engine_user=""
  engine_pass=""
  else
  engine_host="$NBI_PROXY_HOST"
  engine_port="$NBI_PROXY_PORT"
  engine_user="${NBI_PROXY_USER:-}"
  engine_pass="${NBI_PROXY_PASS:-}"
 fi

 if [[ -n "$engine_user" ]]; then
  printf 'http %s %s %s %s\n' "$engine_host" "$engine_port" "$engine_user" "$engine_pass" >> "$ENGINE_CONF"
 else
  printf 'http %s %s\n' "$engine_host" "$engine_port" >> "$ENGINE_CONF"
  fi
  chmod 600 "$ENGINE_CONF"
}

bootstrap_install_engine() {
  if engine_installed; then
    return 0
  fi

  is_ubuntu || {
    err "$APP_NAME currently supports Ubuntu only."
    return 1
  }

  printf 'Preparing access engine...\n'
  local session rc
  session="$(new_session_dir)"
  log_msg "bootstrap session: $session"

  backup_resolv "$session"
  backup_apt_sources "$session"

  apply_temp_dns || true
  apply_bootstrap_apt_sources || true

  export DEBIAN_FRONTEND=noninteractive
  set +e
  apt-get update
  rc=$?
  if [[ $rc -eq 0 ]]; then
    apt-get install -y proxychains4 curl wget ca-certificates gnupg git lsb-release python3
    rc=$?
  fi
  restore_apt_sources "$session" || true
  restore_resolv "$session" || true
  cleanup_temp_access_files
  rm -f "$session/in-progress"
  if [[ $rc -eq 0 ]]; then
    touch "$session/complete"
  else
    touch "$session/failed"
  fi

  if [[ $rc -ne 0 ]]; then
    err "Could not prepare access engine. Check bootstrap DNS/mirror defaults in the project."
    return "$rc"
  fi

  ok "Access engine is ready."
}

ensure_ready() {
  load_config
  if [[ "${NBI_ENABLED:-0}" != "1" ]]; then
    err "$APP_NAME is disabled. Configure or enable access first."
    return 1
  fi
  if ! has_access_config; then
    err "Access is not configured."
    return 1
  fi

  bootstrap_install_engine || return 1
  ensure_local_bridge || return 1
  write_engine_config || return 1
}

run_access() {
  ensure_ready || return 1
  env -u http_proxy -u https_proxy -u ftp_proxy -u all_proxy \
      -u HTTP_PROXY -u HTTPS_PROXY -u FTP_PROXY -u ALL_PROXY \
      proxychains4 -q -f "$ENGINE_CONF" "$@"
}

run_access_quiet() {
  ensure_ready >/dev/null 2>&1 || return 1
  env -u http_proxy -u https_proxy -u ftp_proxy -u all_proxy \
      -u HTTP_PROXY -u HTTPS_PROXY -u FTP_PROXY -u ALL_PROXY \
      proxychains4 -q -f "$ENGINE_CONF" "$@"
}

