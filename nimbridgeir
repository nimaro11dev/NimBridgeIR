prompt_basic_proxy_input() {
  local scheme="$1"
  local host port user pass auth=""

  NBI_INPUT_RAW=""

  read -rp 'Proxy host/IP or domain: ' host
  host="$(trim "$host")"
  if [[ -z "$host" ]]; then
    err "Proxy host cannot be empty."
    return 1
  fi

  read -rp 'Proxy port: ' port
  if ! validate_port "$port"; then
    err "Invalid port."
    return 1
  fi

  read -rp 'Username (optional): ' user
  if [[ -n "$user" ]]; then
    read -rsp 'Password: ' pass
    printf '\n'
    auth="$(urlencode "$user"):$(urlencode "$pass")@"
  fi

  NBI_INPUT_RAW="${scheme}://${auth}${host}:${port}"
}

configure_access() {
  print_header
  bold "Configure Access"
  printf 'Choose your access type.\n\n'
  cat <<EOF_ACCESS
1) HTTP proxy
2) SOCKS proxy
3) VLESS link
4) VMess link
0) Back
EOF_ACCESS
  printf '\n'
 
  local raw proxy_choice

 local old_enabled old_type old_raw old_host old_port old_user old_pass old_bridge_port

 old_enabled="${NBI_ENABLED:-0}"
 old_type="${NBI_PROXY_TYPE:-http}"
 old_raw="${NBI_PROXY_RAW:-}"
 old_host="${NBI_PROXY_HOST:-}"
 old_port="${NBI_PROXY_PORT:-}"
 old_user="${NBI_PROXY_USER:-}"
 old_pass="${NBI_PROXY_PASS:-}"
 old_bridge_port="${NBI_BRIDGE_PORT:-}"
 
  read -rp 'Choose: ' proxy_choice
  case "$proxy_choice" in
    1)
      prompt_basic_proxy_input "http" || { pause; return 1; }
      raw="$NBI_INPUT_RAW"
      ;;
    2)
      prompt_basic_proxy_input "socks5" || { pause; return 1; }
      raw="$NBI_INPUT_RAW"
      ;;
    3)
      read -rp 'VLESS link: ' raw
      ;;
    4)
      read -rp 'VMess link: ' raw
      ;;
    0)
      return 0
      ;;
    *)
      warn "Invalid option."
      pause; return 1
      ;;
  esac

 if ! command -v python3 >/dev/null 2>&1; then
  bootstrap_install_engine || { pause; return 1; }
 fi

  parse_access_input "$raw" || { pause; return 1; }
  if ! bridge_needed; then
    NBI_BRIDGE_PORT=""
  fi

  if bootstrap_install_engine && ensure_local_bridge 1 && write_engine_config; then
    if ! bridge_needed; then
      stop_local_bridge
    fi

    NBI_ENABLED=1
    save_config
    ok "Access configured successfully."
    check_connection_compact || true
  else
    NBI_ENABLED="$old_enabled"
    NBI_PROXY_TYPE="$old_type"
    NBI_PROXY_RAW="$old_raw"
    NBI_PROXY_HOST="$old_host"
    NBI_PROXY_PORT="$old_port"
    NBI_PROXY_USER="$old_user"
    NBI_PROXY_PASS="$old_pass"
    NBI_BRIDGE_PORT="$old_bridge_port"
    save_config

    if [[ "$old_enabled" == "1" && "$old_type" != "http" ]]; then
      ensure_local_bridge 1 || true
    else
      stop_local_bridge
    fi

    err "Access configuration failed. Previous settings were restored."
  fi
  pause
}

check_url() {
  local label="$1" url="$2" code
  printf '%-20s' "$label:"
  code="$(run_access_quiet curl -L -sS -o /dev/null -w '%{http_code}' --connect-timeout 15 --max-time 25 "$url" 2>/dev/null || printf '000')"
  if [[ "$code" != "000" ]]; then
    printf 'OK (%s)\n' "$code"
    return 0
  fi
  printf 'Failed\n'
  return 1
}

check_connection_compact() {
  printf '\nChecking connection...\n'
  check_url 'General HTTPS' "$NBI_TEST_URL_GENERAL" || true
  check_url 'Ubuntu packages' "$NBI_TEST_URL_UBUNTU" || true
  check_url 'GitHub' "$NBI_TEST_URL_GITHUB" || true
  check_url 'Docker registry' "$NBI_TEST_URL_DOCKER" || true
}

check_connection_menu() {
  print_header
  bold "Check Connection"
  check_connection_compact
  pause
}

update_ubuntu_packages() {
  print_header
  bold "Update Ubuntu Packages"
  printf 'Updating Ubuntu package lists...\n'
  cleanup_temp_access_files
  if run_access apt-get update; then
    ok "Ubuntu package lists updated."
  else
    err "Update failed."
  fi
  pause
}

install_ubuntu_package() {
  print_header
  bold "Install Ubuntu Package"
  local pkg
  read -rp 'Package name: ' pkg
  if [[ ! "$pkg" =~ ^[A-Za-z0-9.+:_-]+$ ]]; then
    err "Invalid package name."
    pause; return 1
  fi
  cleanup_temp_access_files
  if run_access apt-get install -y "$pkg"; then
    ok "Package installed: $pkg"
  else
    err "Package installation failed: $pkg"
  fi
  pause
